---
// ThemeToggle — component de canvi mode clar/fosc
---

<button class="theme-toggle" aria-label="Canviar mode clar/fosc" title="Canviar mode clar/fosc">
  <!-- Lluna: visible en mode clar -->
  <svg class="icona-lluna" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
  </svg>

  <!-- Sol: visible en mode fosc -->
  <svg class="icona-sol" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="12" cy="12" r="5"/>
    <line x1="12" y1="1" x2="12" y2="3"/>
    <line x1="12" y1="21" x2="12" y2="23"/>
    <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
    <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
    <line x1="1" y1="12" x2="3" y2="12"/>
    <line x1="21" y1="12" x2="23" y2="12"/>
    <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
    <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
  </svg>
</button>

<style>
  .theme-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    padding: 0;
    background: transparent;
    border: none;
    border-radius: var(--radius-sm);
    cursor: pointer;
    color: var(--text-primary);
    position: relative;
    overflow: hidden;
  }

  .icona-lluna,
  .icona-sol {
    position: absolute;
  }

  /* MODE CLAR: lluna visible, sol amagat */
  :global([data-theme="light"]) .icona-lluna {
    opacity: 1;
    transform: rotate(0deg);
  }
  :global([data-theme="light"]) .icona-sol {
    opacity: 0;
    transform: rotate(90deg);
  }

  /* MODE FOSC: sol visible, lluna amagada */
  :global([data-theme="dark"]) .icona-lluna {
    opacity: 0;
    transform: rotate(-20deg);
  }
  :global([data-theme="dark"]) .icona-sol {
    opacity: 1;
    transform: rotate(0deg);
  }

  /* Estat per defecte (abans que l'script escrigui data-theme) */
  .icona-lluna { opacity: 1; transform: rotate(0deg); }
  .icona-sol   { opacity: 0; transform: rotate(90deg); }

  @media (prefers-reduced-motion: no-preference) {
    .icona-lluna,
    .icona-sol {
      transition: opacity 200ms ease-out, transform 200ms ease-out;
    }
    .theme-toggle {
      transition: color 150ms ease-out;
    }
  }

  .theme-toggle:hover {
    color: var(--accent-green);
  }
</style>

<script>
  // ─── NOTA: aquest script NO usa astro:page-load ───────────────────────────
  // Astro deduplicà scripts mòdul: aquest bloc s'executa UNA SOLA VEGADA
  // per sessió, independentment de quantes vegades es navegui.
  // Usar astro:page-load aquí causaria listeners duplicats en cada navegació.

  // Re-aplica el tema després de cada swap de ClientRouter
  // (el data-theme persisteix a <html>, però el re-apliquem per seguretat)
  function applyTheme() {
    const saved = localStorage.getItem('theme');
    const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
    const theme = (saved === 'dark' || (!saved && prefersDark)) ? 'dark' : 'light';
    document.documentElement.setAttribute('data-theme', theme);
  }

  document.addEventListener('astro:after-swap', applyTheme);

  // Toggle via event delegation — UN sol listener, cobreix tots els botons
  // (n'hi ha dos: header escriptori + menú mòbil)
  document.addEventListener('click', (e) => {
    if (!(e.target as Element).closest('.theme-toggle')) return;
    const html = document.documentElement;
    const next = html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
    html.setAttribute('data-theme', next);
    localStorage.setItem('theme', next);
  });
</script>
