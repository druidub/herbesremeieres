---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Inici - Herbolari Arrel Digital">
  
  <section class="hero">
    <div class="hero-contingut">
      <span class="etiqueta-intro">Projecte de divulgació</span>
      <h1>Recuperant la saviesa de la terra</h1>
      <p>Arreldigital és una iniciativa dedicada a preservar, classificar i compartir el coneixement tradicional de les plantes medicinals i l'etnobotànica per a les futures generacions.</p>
      
      <div class="botons">
        <a href="/cataleg" class="boto boto-primari">Explorar el Catàleg &rarr;</a>
        <a href="#projecte" class="boto boto-secundari">Coneix la iniciativa</a>
      </div>
    </div>
    
    <div class="hero-imatge">
      <img src="https://images.unsplash.com/photo-1466692476868-aef1dfb1e735?auto=format&fit=crop&w=1200&q=80" alt="Camps de plantes medicinals i flors" />
    </div>
  </section>

  <section id="projecte" class="valors-container">
    <div class="valor">
      <div class="icona">🌿</div>
      <h2>Tradició Viva</h2>
      <p>Documentem els usos populars i els remeis ancestrals abans que es perdin en l'oblit i la memòria.</p>
    </div>
    <div class="valor">
      <div class="icona">🔬</div>
      <h2>Rigor Botànic</h2>
      <p>Classifiquem cada espècie amb la seva taxonomia exacta i creuem dades amb estudis científics moderns.</p>
    </div>
    <div class="valor">
      <div class="icona">🤝</div>
      <h2>Comunitat</h2>
      <p>Una plataforma digital oberta i accessible per aprendre i reconnectar amb el nostre entorn natural proper.</p>
    </div>
  </section>

</Layout>

<style>
  /* --- HERO SECTION --- */
  .hero {
    display: flex;
    align-items: center;
    gap: 3.5rem;
    min-height: 75vh;
    padding-top: 2rem;
  }
  
  .hero-contingut {
    flex: 1;
    max-width: 600px;
  }

  .etiqueta-intro {
    display: inline-block;
    background: #eef2eb;
    color: #2d5a27;
    padding: 0.4rem 1rem;
    border-radius: 99px;
    font-weight: 700;
    font-size: 0.9rem;
    letter-spacing: 1px;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
  }

  .hero h1 {
    font-size: 3.9rem;
    line-height: 1.1;
    color: #1a3a16;
    margin-bottom: 1.5rem;
    margin-top: 0;
  }

  .hero p {
    font-size: 1.2rem;
    color: #555;
    margin-bottom: 2.5rem;
    line-height: 1.8;
  }

  .botons {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .boto {
    padding: 1rem 2rem;
    border-radius: 8px;
    font-weight: 600;
    font-size: 1.1rem;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .boto-primari {
    background: #2d5a27;
    color: white;
    box-shadow: 0 4px 14px rgba(45, 90, 39, 0.3);
  }

  .boto-primari:hover {
    background: #1f421b;
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(45, 90, 39, 0.4);
  }

  .boto-secundari {
    background: transparent;
    color: #2d5a27;
    border: 2px solid #2d5a27;
  }

  .boto-secundari:hover {
    background: #eef2eb;
  }

  .hero-imatge {
    flex: 1;
    position: relative;
  }

  .hero-imatge img {
    width: 100%;
    height: 600px;
    object-fit: cover;
    border-radius: 24px;
    box-shadow: 0 20px 40px -10px rgba(0,0,0,0.15);
    animation: flotar 6s ease-in-out infinite alternate;
  }

  @keyframes flotar {
    0% { transform: translateY(0px); }
    100% { transform: translateY(-15px); }
  }

  /* --- VALORS (FUNDACIÓ) --- */
  .valors-container {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 3rem;
    margin-top: 5rem;
    margin-bottom: 5rem;
    padding-top: 5rem;
    border-top: 1px solid #eaeaea;
  }

  .valor {
    background: white;
    padding: 2.5rem;
    border-radius: 16px;
    border: 1px solid #f1f1f1;
    box-shadow: 0 10px 30px -5px rgba(0,0,0,0.05);
    transition: transform 0.3s ease;
  }

  .valor:hover {
    transform: translateY(-10px);
  }

  .icona {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .valor h2 {
    color: #2d5a27;
    margin-top: 0;
    margin-bottom: 1rem;
    font-size: 1.5rem;
  }

  .valor p {
    color: #666;
    margin: 0;
  }

  /* --- RESPONSIVE PER MÒBILS --- */
  @media (max-width: 992px) {
    .hero {
      flex-direction: column;
      text-align: center;
      padding-top: 0;
    }
    .hero-contingut {
      max-width: 100%;
    }
    .hero h1 {
      font-size: 2.8rem;
    }
    .botons {
      justify-content: center;
    }
    .hero-imatge img {
      height: 400px;
    }
  }
</style>