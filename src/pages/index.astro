---
import Layout from '../layouts/Layout.astro';
import axios from 'axios';

let plantesDestacades = [];
let afeccionsReals = [];
try {
  const resposta = await axios.post(import.meta.env.WP_GRAPHQL_URL, {
    query: `
      query ObtenirPlantes {
        plantes(first: 100) {
          nodes {
            slug
            title
            featuredImage {
              node {
                sourceUrl
                altText
              }
            }
            propietats {
              nodes { name }
            }
            familiesBotaniques {
              nodes { name }
            }
            dadesBotaniques {
              nomCientific
              usosMedicinals
            }
            afeccions {
              nodes { name slug }
            }
          }
        }
      }
    `
  });
  // El shuffle es fa al CLIENT per garantir aleatoreïtat real a cada visita
  plantesDestacades = resposta.data?.data?.plantes?.nodes || [];

  // Extreure afeccions úniques de totes les plantes (mateix patró que cataleg.astro)
  const totesAfeccions: { name: string; slug: string }[] = [];
  plantesDestacades.forEach((planta: any) => {
    planta.afeccions?.nodes?.forEach((afeccio: any) => {
      if (!totesAfeccions.some(a => a.slug === afeccio.slug)) {
        totesAfeccions.push(afeccio);
      }
    });
  });
  afeccionsReals = totesAfeccions.sort((a, b) => a.name.localeCompare(b.name));
  console.log('[index] Slugs afeccions:', afeccionsReals.map((a: any) => a.slug));
} catch (e) {
  // silenci: si falla, les seccions no es mostren
}
---

<Layout title="Inici - Herbes Remeieres">

  <section class="hero">

    <!-- Decoració de fons: 5 corbes orgàniques tipo tiges de planta -->
    <svg class="hero-decoracio" viewBox="0 0 1440 600" preserveAspectRatio="none" fill="none" aria-hidden="true" focusable="false">
      <!-- Tija 1: ondulada baixa, travessa tot l'ample -->
      <path d="M-20,480 C180,380 320,520 520,420 C680,340 820,460 1020,380 C1180,320 1300,420 1460,360" stroke="currentColor" stroke-width="1.5"/>


      <!-- Tija 2: alta, corba inversa -->
      <path d="M-20,120 C200,200 380,80 620,160 C820,230 980,100 1200,180 C1320,220 1400,150 1460,140" stroke="currentColor" stroke-width="1"/>


      <!-- Tija 3: diagonal suau -->
      <path d="M-20,280 C280,220 560,320 820,240 C1020,180 1240,280 1460,220" stroke="currentColor" stroke-width="2"/>


      <!-- Tija 4: quasi horitzontal, molt subtil -->
      <path d="M-20,560 C360,540 720,570 1080,545 C1260,533 1380,550 1460,542" stroke="currentColor" stroke-width="0.8"/>

      <!-- Tija 5: arc llarg pel mig -->
      <path d="M-20,380 C320,280 680,440 1020,320 C1200,260 1360,340 1460,300" stroke="currentColor" stroke-width="1.2"/>
      <path d="M680,440 C700,412 728,406 724,432" stroke="currentColor" stroke-width="0.9"/>
    </svg>

    <!-- Planta decorativa esquerra (semiparcialment visible) -->
    <div class="planta-marge planta-marge-esquerra" aria-hidden="true">
      <img src="/il·lustracions/dibuix-pota-cavall.svg" alt="" width="200" height="250" />
    </div>

    <!-- Planta decorativa dreta -->
    <div class="planta-marge planta-marge-dreta" aria-hidden="true">
      <img src="/il·lustracions/dibuix-hiperic.svg" alt="" width="200" height="250" />
    </div>

    <div class="hero-contingut">
      <p class="etiqueta-region">Herbari Digital · Bages i Moianès</p>

      <h1>Recuperant la saviesa<br>de la terra</h1>

      <p class="subtitol">Plantes medicinals, remeis ancestrals i el coneixement etnobotànic del Bages i el Moianès que no podem deixar perdre.</p>

      <div class="botons">
        <a href="/herbari" class="boto boto-primari">Explorar l'herbari</a>
        <a href="/projecte" class="boto boto-secundari">Coneix el projecte</a>
      </div>

      <div class="plantes-botaniques">

        <div class="planta-item planta-1">
          <div class="planta-imatge-wrap">
            <img src="/il·lustracions/dibuix-camamilla.svg" alt="Il·lustració de camamilla" class="planta-img" width="90" height="110" />
          </div>
          <span class="planta-nom">Camamilla</span>
        </div>

        <div class="planta-item planta-2">
          <div class="planta-imatge-wrap">
            <img src="/il·lustracions/dibuix-dent-lleo.svg" alt="Il·lustració de dent de lleó" class="planta-img" width="90" height="110" />
          </div>
          <span class="planta-nom">Dent de lleó</span>
        </div>

        <div class="planta-item planta-3">
          <div class="planta-imatge-wrap">
            <img src="/il·lustracions/dibuix-hiperic.svg" alt="Il·lustració d'hipèric" class="planta-img" width="90" height="110" />
          </div>
          <span class="planta-nom">Hipèric</span>
        </div>

        <div class="planta-item planta-4">
          <div class="planta-imatge-wrap">
            <img src="/il·lustracions/dibuix-pimpinella.svg" alt="Il·lustració de pimpinella" class="planta-img" width="90" height="110" />
          </div>
          <span class="planta-nom">Pimpinella</span>
        </div>

        <div class="planta-item planta-5">
          <div class="planta-imatge-wrap">
            <img src="/il·lustracions/dibuix-plantatge-fulla-gran.svg" alt="Il·lustració de plantatge" class="planta-img" width="90" height="110" />
          </div>
          <span class="planta-nom">Plantatge</span>
        </div>

      </div>
    </div>
  </section>

  <section class="valors-container">

    <article class="valor">
      <div class="valor-icona">
        <img src="/il·lustracions/tradicio-viva.svg" class="valor-icona-img" width="40" height="40" alt="" aria-hidden="true">
      </div>
      <h2>Tradició Viva</h2>
      <p>Documentem els usos populars i els remeis ancestrals abans que es perdin en l'oblit i la memòria.</p>
    </article>

    <article class="valor">
      <div class="valor-icona">
        <img src="/il·lustracions/rigor-botanic.svg" class="valor-icona-img" width="40" height="40" alt="" aria-hidden="true">
      </div>
      <h2>Rigor Botànic</h2>
      <p>Classifiquem cada espècie amb la seva taxonomia exacta i creuem dades amb estudis científics moderns.</p>
    </article>

    <article class="valor">
      <div class="valor-icona">
        <img src="/il·lustracions/comunitat.svg" class="valor-icona-img" width="40" height="40" alt="" aria-hidden="true">
      </div>
      <h2>Comunitat</h2>
      <p>Una plataforma digital oberta i accessible per aprendre i reconnectar amb el nostre entorn natural proper.</p>
    </article>

  </section>

  <!-- ═══ SECCIÓ 1: PLANTES DESTACADES ═══ -->
  {plantesDestacades.length > 0 && (
    <section class="seccio-destacades observable">
      <div class="seccio-inner">
        <header class="seccio-cap">
          <h2>Descobreix les nostres plantes</h2>
          <p class="seccio-subtitol">Cada visita et porta plantes diferents</p>
        </header>

        <div class="grid-plantes">
          {plantesDestacades.map((planta) => (
            <article class="card-planta">
              {planta.featuredImage?.node && (
                <div class="card-img-wrap">
                  <img
                    src={planta.featuredImage.node.sourceUrl}
                    alt={planta.featuredImage.node.altText || planta.title}
                    loading="lazy"
                    width="400"
                    height="300"
                  />
                </div>
              )}
              <div class="card-cos">
                {planta.familiesBotaniques?.nodes?.[0] && (
                  <p class="card-familia">{planta.familiesBotaniques.nodes[0].name}</p>
                )}
                <h3>{planta.title}</h3>
                {planta.dadesBotaniques?.nomCientific && (
                  <p class="scientific-name">{planta.dadesBotaniques.nomCientific}</p>
                )}
                {planta.propietats?.nodes?.length > 0 && (
                  <div class="card-tags">
                    {planta.propietats.nodes.slice(0, 3).map((prop) => (
                      <span class="tag">{prop.name}</span>
                    ))}
                  </div>
                )}
                <a href={`/planta/${planta.slug}`} class="card-link">Saber-ne més <span class="fletxa">→</span></a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ═══ SECCIÓ 2: EXPLORA PER AFECCIÓ ═══ -->
  <section class="seccio-afeccions observable">
    <div class="seccio-inner">
      <header class="seccio-cap">
        <h2>Quin malestar vols alleujar?</h2>
        <p class="seccio-subtitol">Troba plantes per al que necessites</p>
      </header>

      <div class="grid-afeccions">

        {afeccionsReals.map((afeccio: any) => (
            <a href={`/herbari?afeccio=${afeccio.slug}`} class="card-afeccio">
              <img
                src={`/il·lustracions/${afeccio.slug}.svg`}
                class="afeccio-icona"
                width="48"
                height="48"
                alt=""
                aria-hidden="true"
                loading="lazy"
                onerror="this.style.display='none'"
              />
              <span class="afeccio-nom">{afeccio.name}</span>
            </a>
        ))}

      </div>
    </div>
  </section>

  <!-- ═══ SECCIÓ 3: SOBRE EL PROJECTE ═══ -->
  <section class="seccio-projecte observable">
    <div class="seccio-projecte-inner">
      <p class="etiqueta-seccio">El Projecte</p>
      <h2>Preservem el coneixement de la nostra terra</h2>
      <p class="projecte-text">Les herbes remeieres formen part del nostre patrimoni natural i etnogràfic. Des del Bages i el Moianès, documentem la saviesa que les generacions anteriors ens han transmès de viva veu, abans que es perdi per sempre.</p>
      <a href="/projecte" class="boto boto-secundari">Coneix el projecte <span class="fletxa">→</span></a>
    </div>
  </section>

</Layout>

<style>
  /* ─── HERO ──────────────────────────────────────── */
  .hero {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 90vh;
    text-align: center;
    overflow: hidden;
    /* Trenca el contenidor max-width del <main> per ocupar tot l'ample del viewport */
    width: 100vw;
    margin-left: calc(50% - 50vw);
  }

  /* ─── DECORACIÓ DE FONS ─────────────────────────── */
  .hero-decoracio {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    color: var(--accent-green);
    opacity: 0.055;
    z-index: 0;
    pointer-events: none;
  }

  /* ─── PLANTES ALS MARGES ────────────────────────── */
  .planta-marge {
    position: absolute;
    bottom: 0;
    z-index: 0;
    pointer-events: none;
  }

  .planta-marge img {
    height: 240px;
    width: auto;
    opacity: 0.1;
    display: block;
  }

  .planta-marge-esquerra {
    left: -70px;
  }

  .planta-marge-dreta {
    right: -60px;
    transform: scaleX(-1);
  }

  /* Mode fosc: invertir les il·lustracions dels marges */
  :global([data-theme="dark"] .planta-marge img) {
    filter: brightness(0) invert(1) opacity(0.55);
  }

  /* ─── CONTINGUT HERO ────────────────────────────── */
  .hero-contingut {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 3rem 1.5rem;
    width: 100%;
  }

  /* ─── TIPOGRAFIA HERO ───────────────────────────── */
  .etiqueta-region {
    font-family: var(--font-body);
    font-size: 12px;
    letter-spacing: 0.12em;
    color: var(--text-tertiary);
    text-transform: uppercase;
    margin: 0 0 var(--sp-5) 0;
  }

  .hero-contingut h1 {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw, 3.5rem);
    font-weight: 400;
    letter-spacing: -0.03em;
    line-height: 1.1;
    color: var(--text-primary);
    max-width: 650px;
    margin: 0 0 var(--sp-5) 0;
  }

  .subtitol {
    font-family: var(--font-body);
    font-size: 16px;
    color: var(--text-secondary);
    max-width: 480px;
    line-height: 1.7;
    margin: 0 0 var(--sp-6) 0;
  }

  /* ─── BOTONS ────────────────────────────────────── */
  .botons {
    display: flex;
    gap: var(--sp-3);
    flex-wrap: wrap;
    justify-content: center;
    margin-bottom: var(--sp-7);
  }

  .boto {
    padding: 0.75rem 1.75rem;
    border-radius: var(--radius-sm);
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 500;
    text-decoration: none;
    display: inline-block;
  }

  .boto-primari {
    background: var(--accent-green);
    color: var(--bg-primary);
    border: 1px solid transparent;
  }

  .boto-secundari {
    background: transparent;
    color: var(--accent-green);
    border: 1px solid var(--accent-green);
  }

  @media (prefers-reduced-motion: no-preference) {
    .boto {
      transition: background 150ms ease-out, color 150ms ease-out, transform 150ms ease-out;
    }
    .boto-primari:hover {
      background: var(--accent-green-hover);
      transform: translateY(-1px);
    }
    .boto-secundari:hover {
      background: var(--accent-green-soft);
      transform: translateY(-1px);
    }
    .boto:active {
      transform: scale(0.98);
    }
  }

  /* ─── IL·LUSTRACIONS BOTÀNIQUES ─────────────────── */
  .plantes-botaniques {
    display: flex;
    gap: 40px;
    align-items: flex-end;
    justify-content: center;
  }

  .planta-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--sp-2);
  }

  .planta-imatge-wrap {
    /* El clip-path s'aplica aquí, no al img, per no afectar el nom */
    display: flex;
    align-items: flex-end;
    height: 110px;
  }

  .planta-img {
    height: 110px;
    width: auto;
    display: block;
    object-fit: contain;
  }

  /* Mode clar: les imatges (fill:#261414) es veuen bé tal qual */
  /* Mode fosc: invertim per veure-les sobre fons fosc */
  :global([data-theme="dark"] .planta-img) {
    filter: brightness(0) invert(1) opacity(0.65);
  }

  .planta-nom {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 15px;
    color: var(--text-secondary);
    letter-spacing: 0.01em;
    white-space: nowrap;
  }

  /* ─── SECCIÓ VALORS ─────────────────────────────── */
  .valors-container {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--sp-5);
    margin-top: var(--sp-8);
    margin-bottom: var(--sp-8);
    padding-top: var(--sp-7);
    border-top: 1px solid var(--border-subtle);
  }

  .valor {
    background: var(--bg-secondary);
    padding: var(--sp-6);
    border-radius: var(--radius-md);
    border: 0.5px solid var(--border-subtle);
  }

  @media (prefers-reduced-motion: no-preference) {
    .valor {
      transition: transform 200ms ease-out, border-color 200ms ease-out;
    }
    .valor:hover {
      transform: translateY(-2px);
      border-color: var(--accent-green);
    }
  }

  .valor-icona {
    color: var(--accent-green);
    margin-bottom: var(--sp-4);
  }

  .valor-icona-img {
    height: 40px;
    width: 40px;
    object-fit: contain;
  }

  :global([data-theme="dark"]) .valor-icona-img {
    filter: brightness(0) invert(1) opacity(0.7);
  }

  .valor h2 {
    font-size: 1.375rem;
    font-weight: 500;
    color: var(--text-primary);
    margin-top: 0;
    margin-bottom: var(--sp-3);
  }

  .valor p {
    color: var(--text-secondary);
    margin: 0;
    line-height: 1.7;
    font-size: 0.95rem;
  }

  /* ─── ANIMACIONS ────────────────────────────────── */
  @media (prefers-reduced-motion: no-preference) {

    /* Entrada del contingut del hero */
    .hero-contingut > .etiqueta-region,
    .hero-contingut > h1,
    .hero-contingut > .subtitol,
    .hero-contingut > .botons {
      animation: fadeUp 300ms cubic-bezier(0.22, 1, 0.36, 1) both;
    }
    .hero-contingut > .etiqueta-region { animation-delay: 0ms; }
    .hero-contingut > h1              { animation-delay: 60ms; }
    .hero-contingut > .subtitol       { animation-delay: 120ms; }
    .hero-contingut > .botons         { animation-delay: 180ms; }

    /* Animació de creixement per a les imatges de plantes */
    /* El clip-path anima de baix a dalt, com si creixessin */
    @keyframes creixement {
      from {
        clip-path: inset(100% 0 0 0);
        transform: scale(0.95);
      }
      to {
        clip-path: inset(0% 0 0 0);
        transform: scale(1);
      }
    }

    /* Noms: apareixen amb fade un cop la planta ha crescut */
    @keyframes fadeIn {
      from { opacity: 0; }
      to   { opacity: 1; }
    }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(8px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* Plantes principals: stagger 150ms */
    .planta-1 .planta-imatge-wrap { animation: creixement 800ms cubic-bezier(0.22, 1, 0.36, 1) 300ms both; }
    .planta-2 .planta-imatge-wrap { animation: creixement 800ms cubic-bezier(0.22, 1, 0.36, 1) 450ms both; }
    .planta-3 .planta-imatge-wrap { animation: creixement 800ms cubic-bezier(0.22, 1, 0.36, 1) 600ms both; }
    .planta-4 .planta-imatge-wrap { animation: creixement 800ms cubic-bezier(0.22, 1, 0.36, 1) 750ms both; }
    .planta-5 .planta-imatge-wrap { animation: creixement 800ms cubic-bezier(0.22, 1, 0.36, 1) 900ms both; }

    /* Noms: delay = delay_planta + 700ms (quan la planta ja ha crescut del tot) */
    .planta-1 .planta-nom { animation: fadeIn 300ms ease-out 1000ms both; }
    .planta-2 .planta-nom { animation: fadeIn 300ms ease-out 1150ms both; }
    .planta-3 .planta-nom { animation: fadeIn 300ms ease-out 1300ms both; }
    .planta-4 .planta-nom { animation: fadeIn 300ms ease-out 1450ms both; }
    .planta-5 .planta-nom { animation: fadeIn 300ms ease-out 1600ms both; }

    /* Plantes dels marges: més lentes i amb més delay */
    .planta-marge-esquerra { animation: creixement 1200ms cubic-bezier(0.22, 1, 0.36, 1) 1000ms both; }
    .planta-marge-dreta    { animation: creixement 1200ms cubic-bezier(0.22, 1, 0.36, 1) 1200ms both; }

    /* Stagger per les cards de valors */
    .valors-container .valor:nth-child(1) { animation: fadeUp 200ms cubic-bezier(0.22, 1, 0.36, 1) 0ms both; }
    .valors-container .valor:nth-child(2) { animation: fadeUp 200ms cubic-bezier(0.22, 1, 0.36, 1) 40ms both; }
    .valors-container .valor:nth-child(3) { animation: fadeUp 200ms cubic-bezier(0.22, 1, 0.36, 1) 80ms both; }
  }

  /* Sense animació: tot visible directament */
  @media (prefers-reduced-motion: reduce) {
    .planta-imatge-wrap,
    .planta-nom,
    .planta-marge-esquerra,
    .planta-marge-dreta {
      clip-path: none;
      opacity: 1;
    }
  }

  /* ─── RESPONSIVE ────────────────────────────────── */
  @media (max-width: 768px) {
    /* Amaguem les plantes dels marges */
    .planta-marge { display: none; }

    /* 4 plantes: s'amaga la pimpinella (planta-4) */
    .planta-4 { display: none; }

    .planta-img {
      height: 90px;
    }
    .planta-imatge-wrap {
      height: 90px;
    }
    .plantes-botaniques {
      gap: var(--sp-5);
    }
    .planta-nom {
      font-size: 13px;
    }
  }

  @media (max-width: 480px) {
    /* 3 plantes: s'amaga també plantatge (planta-5) */
    .planta-5 { display: none; }

    .planta-img {
      height: 80px;
    }
    .planta-imatge-wrap {
      height: 80px;
    }
    .plantes-botaniques {
      gap: var(--sp-4);
    }
    .botons {
      flex-direction: column;
      width: 100%;
      max-width: 280px;
    }
    .boto {
      width: 100%;
      text-align: center;
    }
  }

  /* ══════════════════════════════════════════════════
     SECCIONS NOVES — base compartida
  ══════════════════════════════════════════════════ */

  .seccio-destacades,
  .seccio-afeccions,
  .seccio-projecte {
    width: 100vw;
    margin-left: calc(50% - 50vw);
    border-top: 1px solid var(--border-subtle);
  }

  .seccio-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: var(--sp-8) var(--sp-6);
  }

  .seccio-cap {
    text-align: center;
    margin-bottom: var(--sp-7);
  }

  .seccio-cap h2 {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3vw, 2.25rem);
    font-weight: 400;
    letter-spacing: -0.02em;
    color: var(--text-primary);
    margin: 0 0 var(--sp-2) 0;
  }

  .seccio-subtitol {
    font-family: var(--font-body);
    font-size: 15px;
    color: var(--text-tertiary);
    margin: 0;
  }

  /* ── SECCIÓ 1: PLANTES DESTACADES ─────────────── */

  .grid-plantes {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: var(--sp-5);
  }

  .card-planta {
    background: var(--bg-secondary);
    border: 0.5px solid var(--border-subtle);
    border-radius: var(--radius-md);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    /* Estat inicial per a l'animació */
    opacity: 0;
