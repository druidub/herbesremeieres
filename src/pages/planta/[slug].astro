---
import axios from 'axios';
import Layout from '../../layouts/Layout.astro';
import { Image } from 'astro:assets';

export async function getStaticPaths() {
  const resposta = await axios.post(import.meta.env.WP_GRAPHQL_URL, {
    query: `
      query TotesLesPlantes {
        plantes(first: 100) {
          nodes {
            slug
            title
            content
            featuredImage { node { sourceUrl altText } }
            propietats { nodes { name } }
            familiesBotaniques { nodes { name } }
            afeccions { nodes { name slug } }
            dadesBotaniques {
              nomCientific
              altresNomsComuns
              descripcio
              usosMedicinals
              precaucions
              nivellPrecaucio
              epocaDeRecolLeccio
              preparacions {
                tipus
                instruccions
              }
            }
          }
        }
      }
    `
  });

  const totesLesPlantes = resposta.data?.data?.plantes?.nodes || [];

  return totesLesPlantes.map((plantaActual) => {
    const propietatsActuals = plantaActual.propietats?.nodes?.map(p => p.name) || [];

    const plantesRelacionades = totesLesPlantes.filter(altraPlanta => {
      if (altraPlanta.slug === plantaActual.slug) return false;
      const propietatsAltraPlanta = altraPlanta.propietats?.nodes?.map(p => p.name) || [];
      return propietatsActuals.some(prop => propietatsAltraPlanta.includes(prop));
    }).slice(0, 3);

    return {
      params: { slug: plantaActual.slug },
      props: {
        planta: plantaActual,
        relacionades: plantesRelacionades,
        familiesBotaniques: plantaActual.familiesBotaniques?.nodes || [],
        afeccions: plantaActual.afeccions?.nodes || [],
      },
    };
  });
}

const { planta, relacionades = [], familiesBotaniques = [], afeccions = [] } = Astro.props;

// Dades botàniques
const dades = planta.dadesBotaniques || {};
const nomCientific = dades.nomCientific;
const altresNoms = dades.altresNomsComuns;
const descripcio = dades.descripcio;
const usosMedicinals = dades.usosMedicinals;
const precaucions = dades.precaucions;
const nivellPrecaucio = dades.nivellPrecaucio?.[0];
const epocaDeRecolLeccio = dades.epocaDeRecolLeccio || [];
const preparacions = dades.preparacions || [];
const familia = familiesBotaniques[0]?.name;

// Mapa de noms de preparació
const nomsPreparacio: Record<string, string> = {
  'infusio': 'Infusió',
  'decoccio': 'Decocció',
  'cataplasma': 'Cataplasma',
  'oli-macerat': 'Oli macerat',
  'xarop': 'Xarop',
  'tintura': 'Tintura',
  'bany': 'Bany',
  'gargarisme': 'Gargarisme',
};

// Mesos en català
const mesos = [
  { num: '1', abrev: 'G' },
  { num: '2', abrev: 'F' },
  { num: '3', abrev: 'M' },
  { num: '4', abrev: 'A' },
  { num: '5', abrev: 'Mg' },
  { num: '6', abrev: 'Jn' },
  { num: '7', abrev: 'Jl' },
  { num: '8', abrev: 'Ag' },
  { num: '9', abrev: 'S' },
  { num: '10', abrev: 'O' },
  { num: '11', abrev: 'N' },
  { num: '12', abrev: 'D' },
];

// Icones SVG per tipus de preparació
const iconesPreparacio: Record<string, string> = {
  'infusio': `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 8h1a4 4 0 0 1 0 8h-1"/><path d="M3 8h14v9a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4V8z"/><line x1="6" y1="2" x2="6" y2="4"/><line x1="10" y1="2" x2="10" y2="4"/><line x1="14" y1="2" x2="14" y2="4"/></svg>`,
  'decoccio': `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="10" rx="8" ry="4"/><path d="M4 10v4c0 2.2 3.6 4 8 4s8-1.8 8-4v-4"/><path d="M9 21l-1 2"/><path d="M15 21l1 2"/><path d="M12 21v2"/></svg>`,
  'cataplasma': `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 11V6a2 2 0 0 0-2-2 2 2 0 0 0-2 2"/><path d="M14 10V4a2 2 0 0 0-2-2 2 2 0 0 0-2 2v2"/><path d="M10 10.5V6a2 2 0 0 0-2-2 2 2 0 0 0-2 2v8"/><path d="M18 8a2 2 0 1 1 4 0v6a8 8 0 0 1-8 8H8a8 8 0 0 1-6-3"/><path d="M8 16c1-1.5 3-2 5-1"/></svg>`,
  'oli-macerat': `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M8 2h8l2 6H6l2-6z"/><path d="M6 8v11a3 3 0 0 0 3 3h6a3 3 0 0 0 3-3V8"/><path d="M12 12v4"/><circle cx="12" cy="18" r="1"/></svg>`,
  'xarop': `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M8 2h8l1 5H7l1-5z"/><path d="M7 7v12a3 3 0 0 0 3 3h4a3 3 0 0 0 3-3V7"/><line x1="10" y1="13" x2="14" y2="13"/><line x1="12" y1="11" x2="12" y2="15"/></svg>`,
  'tintura': `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10 2h4v4h-4z"/><path d="M8 6h8v2H8z"/><path d="M8 8v11a3 3 0 0 0 3 3h2a3 3 0 0 0 3-3V8"/><line x1="12" y1="12" x2="12" y2="16"/></svg>`,
  'bany': `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2c-3 0-5 2.5-5 6 0 4.5 5 10 5 10s5-5.5 5-10c0-3.5-2-6-5-6z"/><path d="M12 8v3"/><circle cx="12" cy="13" r="0.5"/></svg>`,
  'gargarisme': `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="10" cy="8" r="6"/><path d="M16 10c0 3-1 5-1 8"/><path d="M18 14c-1 0-2 .5-3 1"/><path d="M18 17c-1 0-2 .5-3 1"/><path d="M18 20c-1 0-2 .5-3 1"/></svg>`,
};
---

<Layout title={`${planta.title} - Herbes Remeieres`}>

  <div class="fitxa-contenidor">

  {/* Breadcrumb */}
  <nav class="breadcrumb page-enter">
    <a href="/herbari" class="breadcrumb-link">
      <span class="fletxa">&larr;</span> Tornar a l'herbari
    </a>
    {familia && (
      <span class="breadcrumb-familia">Familia: {familia}</span>
    )}
  </nav>

  {/* Capçalera 2 columnes */}
  <div class="capcalera stagger-enter">
    {planta.featuredImage?.node && (
      <div class="imatge-wrapper">
        <Image
          src={planta.featuredImage.node.sourceUrl}
          alt={planta.featuredImage.node.altText || planta.title}
          width={800}
          height={600}
        />
      </div>
    )}
    <div class="info">
      <h1>{planta.title}</h1>

      {nomCientific && (
        <p class="scientific-name">{nomCientific}</p>
      )}

      {altresNoms && (
        <p class="altres-noms">Altres noms: {altresNoms}</p>
      )}

      <div class="tags-container">
        {planta.propietats?.nodes?.map((prop) => (
          <span class="tag">{prop.name}</span>
        ))}
      </div>

      {descripcio && (
        <p class="descripcio-breu">{descripcio}</p>
      )}
    </div>
  </div>

  {/* Cos central */}
  <div class="cos">

    {/* Usos Medicinals */}
    <section class="seccio page-enter" style="animation-delay: 120ms;">
      <h2>Usos medicinals</h2>
      <div class="seccio-contingut" set:html={usosMedicinals || '<p>Cap us registrat.</p>'} />
    </section>

    {/* Historia, magia i tradicions */}
    {planta.content && (
      <section class="seccio page-enter" style="animation-delay: 160ms;">
        <h2>Historia, magia i tradicions</h2>
        <div class="seccio-contingut" set:html={planta.content} />
      </section>
    )}

    {/* Com preparar-la */}
    {preparacions.length > 0 && (
      <section class="seccio page-enter" style="animation-delay: 200ms;">
        <h2>Com preparar-la</h2>
        <div class="preparacions-grid">
          {preparacions.map((prep) => {
            const tipusSlug = prep.tipus?.[0] || '';
            const tipusNom = nomsPreparacio[tipusSlug] || tipusSlug;
            const icona = iconesPreparacio[tipusSlug] || '';
            return (
              <div class="preparacio-card">
                <div class="preparacio-header">
                  {icona && <span class="preparacio-icona" set:html={icona} />}
                  <h3 class="preparacio-titol">{tipusNom}</h3>
                </div>
                <div class="preparacio-instruccions" set:html={prep.instruccions} />
              </div>
            );
          })}
        </div>
      </section>
    )}

    {/* Precaucions */}
    {precaucions && (
      <section class="seccio page-enter" style="animation-delay: 240ms;">
        <h2>Precaucions</h2>
        <div class="alerta-precaucions">
          <div class="alerta-header">
            <svg class="alerta-icona" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
              <line x1="12" y1="9" x2="12" y2="13"/>
              <line x1="12" y1="17" x2="12.01" y2="17"/>
            </svg>
            {nivellPrecaucio && nivellPrecaucio !== 'cap' && (
              <span class={`badge-nivell badge-${nivellPrecaucio}`}>
                {nivellPrecaucio === 'lleu' && 'Lleu'}
                {nivellPrecaucio === 'moderat' && 'Moderat'}
                {nivellPrecaucio === 'greu' && 'Greu'}
              </span>
            )}
          </div>
          <div class="alerta-text" set:html={precaucions} />
        </div>
      </section>
    )}

    {/* Quan recollir-la */}
    {epocaDeRecolLeccio.length > 0 && (
      <section class="seccio page-enter" style="animation-delay: 280ms;">
        <h2>Quan recollir-la</h2>
        <div class="calendari">
          {mesos.map((mes) => {
            const actiu = epocaDeRecolLeccio.includes(mes.num);
            return (
              <div class={`mes ${actiu ? 'mes-actiu' : 'mes-inactiu'}`}>
                {mes.abrev}
              </div>
            );
          })}
        </div>
      </section>
    )}
  </div>

  {/* Plantes relacionades */}
  {relacionades.length > 0 && (
    <div class="seccio-relacionades page-enter" style="animation-delay: 320ms;">
      <h2>Plantes relacionades</h2>
      <div class="graella-relacionades">
        {relacionades.map(relacionada => (
          <a href={`/planta/${relacionada.slug}`} class="targeta-relacionada">
            {relacionada.featuredImage?.node && (
              <Image
                src={relacionada.featuredImage.node.sourceUrl}
                alt={relacionada.title}
                width={400}
                height={300}
              />
            )}
            <h4>{relacionada.title}</h4>
            {relacionada.dadesBotaniques?.nomCientific && (
              <p class="scientific-name relacionada-cientific">{relacionada.dadesBotaniques.nomCientific}</p>
            )}
            <span class="relacionada-link">
              Veure fitxa <span class="fletxa">&rarr;</span>
            </span>
          </a>
        ))}
      </div>
    </div>
  )}

  </div>

</Layout>

<style>
  /* ── Contenidor principal ────────────────────────── */
  .fitxa-contenidor {
    max-width: 1000px;
    margin: 0 auto;
  }

  /* ── Breadcrumb ──────────────────────────────────── */
  .breadcrumb {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--sp-5);
    font-size: 14px;
    color: var(--text-tertiary);
  }

  .breadcrumb-link {
    color: var(--text-tertiary);
    text-decoration: none;
    font-family: var(--font-body);
  }

  .breadcrumb-link:hover {
    color: var(--accent-green);
  }

  .breadcrumb-familia {
    font-family: var(--font-body);
  }

  /* ── Capçalera ───────────────────────────────────── */
  .capcalera {
    display: flex;
    gap: var(--sp-7);
    margin-bottom: var(--sp-7);
    align-items: flex-start;
  }

  .imatge-wrapper {
    flex: 0 0 420px;
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .imatge-wrapper img {
    width: 100%;
    max-height: 450px;
    object-fit: cover;
    display: block;
  }

  .info {
    flex: 1;
  }

  h1 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.2;
    color: var(--text-primary);
    margin: 0 0 var(--sp-2) 0;
  }

  .altres-noms {
    font-size: 14px;
    color: var(--text-tertiary);
    font-family: var(--font-body);
    margin: 0 0 var(--sp-4) 0;
  }

  .tags-container {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
    margin-bottom: var(--sp-4);
  }

  .descripcio-breu {
    color: var(--text-secondary);
    line-height: 1.7;
    font-family: var(--font-body);
    margin: 0;
  }

  /* ── Cos central ─────────────────────────────────── */
  .cos {
    padding-top: var(--sp-7);
  }

  .seccio {
    border-top: 1px solid var(--border-subtle);
    padding-top: var(--sp-7);
    margin-top: var(--sp-7);
  }

  .seccio:first-child {
    border-top: none;
    padding-top: 0;
    margin-top: 0;
  }

  .seccio h2 {
    font-family: var(--font-display);
    border-bottom: 1px solid var(--border-subtle);
    padding-bottom: var(--sp-3);
    margin-bottom: var(--sp-6);
    margin-top: 0;
  }

  .seccio-contingut {
    color: var(--text-secondary);
    line-height: 1.7;
    font-family: var(--font-body);
  }

  .seccio-contingut :global(p) {
    margin-bottom: var(--sp-4);
  }

  .seccio-contingut :global(p:last-child) {
    margin-bottom: 0;
  }

  /* ── Preparacions ────────────────────────────────── */
  .preparacions-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--sp-5);
  }

  .preparacio-card {
    background: var(--bg-secondary);
    border: 0.5px solid var(--border-subtle);
    border-radius: var(--radius-md);
    padding: var(--sp-5);
  }

  .preparacio-header {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    margin-bottom: var(--sp-4);
  }

  .preparacio-icona {
    color: var(--accent-green);
    flex-shrink: 0;
    display: flex;
  }

  .preparacio-titol {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 500;
    margin: 0;
    color: var(--text-primary);
  }

  .preparacio-instruccions {
    font-family: var(--font-body);
    color: var(--text-secondary);
    line-height: 1.7;
  }

  .preparacio-instruccions :global(p) {
    margin: 0;
  }

  /* ── Precaucions ─────────────────────────────────── */
  .alerta-precaucions {
    padding: var(--sp-5);
    border-left: 3px solid var(--accent-amber);
    border-radius: 0;
    background: var(--accent-amber-soft);
  }

  .alerta-header {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    margin-bottom: var(--sp-3);
  }

  .alerta-icona {
    color: var(--accent-amber);
    flex-shrink: 0;
  }

  .badge-nivell {
    display: inline-block;
    padding: var(--sp-1) var(--sp-3);
    border-radius: var(--radius-pill);
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 500;
  }

  .badge-lleu {
    background: var(--accent-green-soft);
    color: var(--accent-green);
  }

  .badge-moderat {
    background: var(--accent-amber-soft);
    color: var(--accent-amber);
  }

  .badge-greu {
    background: rgba(139, 58, 58, 0.12);
    color: var(--color-danger);
  }

  .alerta-text {
    font-family: var(--font-body);
    color: var(--text-secondary);
    line-height: 1.7;
  }

  .alerta-text :global(p) {
    margin: 0;
  }

  /* ── Calendari ───────────────────────────────────── */
  .calendari {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .mes {
    width: 40px;
    height: 40px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 500;
  }

  .mes-inactiu {
    background: var(--bg-tertiary);
    color: var(--text-tertiary);
  }

  .mes-actiu {
    background: var(--accent-green);
    color: var(--bg-primary);
  }

  /* ── Plantes relacionades ────────────────────────── */
  .seccio-relacionades {
    border-top: 1px solid var(--border-subtle);
    padding-top: var(--sp-7);
    margin-top: var(--sp-7);
    margin-bottom: var(--sp-7);
  }

  .seccio-relacionades h2 {
    font-family: var(--font-display);
    margin-top: 0;
    margin-bottom: var(--sp-5);
  }

  .graella-relacionades {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-5);
  }

  .targeta-relacionada {
    text-decoration: none;
    color: inherit;
    background: var(--bg-secondary);
    border: 0.5px solid var(--border-subtle);
    border-radius: var(--radius-md);
    overflow: hidden;
    display: block;
  }

  .targeta-relacionada img {
    width: 100%;
    height: 160px;
    object-fit: cover;
    display: block;
  }

  .targeta-relacionada h4 {
    margin: var(--sp-3) var(--sp-4) 0;
    color: var(--text-primary);
    font-size: 1.1rem;
  }

  .relacionada-cientific {
    margin: var(--sp-1) var(--sp-4) 0;
    font-size: 0.9rem;
  }

  .relacionada-link {
    display: block;
    margin: var(--sp-3) var(--sp-4) var(--sp-4);
    font-size: 14px;
    color: var(--accent-green);
    font-family: var(--font-body);
  }

  /* ── Animacions (Emil Kowalski) ──────────────────── */
  @media (prefers-reduced-motion: no-preference) {
    .imatge-wrapper img {
      transition: transform 300ms ease-out;
    }

    .imatge-wrapper:hover img {
      transform: scale(1.02);
    }

    .preparacio-card {
      transition: transform 200ms ease-out, border-color 200ms ease-out;
    }

    .preparacio-card:hover {
      transform: translateY(-2px);
      border-color: var(--accent-green);
    }

    .mes-actiu {
      transition: transform 200ms ease-out;
    }

    .mes-actiu:hover {
      transform: scale(1.08);
    }

    .targeta-relacionada {
      transition: transform 200ms ease-out, border-color 200ms ease-out;
    }

    .targeta-relacionada:hover {
      transform: translateY(-2px);
      border-color: var(--accent-green);
    }

    .breadcrumb-link {
      transition: color 200ms ease-out;
    }
  }

  /* ── Responsive ──────────────────────────────────── */
  @media (max-width: 768px) {
    .capcalera {
      flex-direction: column;
      gap: var(--sp-5);
    }

    .imatge-wrapper {
      flex: none;
      width: 100%;
    }

    .imatge-wrapper img {
      max-height: 400px;
    }

    .graella-relacionades {
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    }
  }

  @media (max-width: 480px) {
    h1 {
      font-size: 1.75rem;
    }

    .preparacions-grid {
      grid-template-columns: 1fr;
    }

    .calendari {
      max-width: calc(6 * 48px);
      margin: 0 auto;
    }

    .graella-relacionades {
      grid-template-columns: 1fr;
    }
  }
</style>
