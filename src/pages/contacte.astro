---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contacte | Herbes Remeieres">
	<main class="max-w-4xl mx-auto px-4 py-12">
		<h1 class="text-4xl font-bold text-verd-fosc mb-6">Contacta amb nosaltres</h1>
		<p class="text-lg text-gray-700 leading-relaxed mb-8">
			Tens algun dubte, suggeriment o vols col·laborar amb nosaltres? 
			Escriu-nos i et respondrem ben aviat.
		</p>
		
		<div class="p-6 bg-gray-50 border border-gray-200 rounded-lg">
			<p class="text-center text-gray-500 italic">El formulari de contacte s'està preparant...</p>
		</div>
	</main>
</Layout>