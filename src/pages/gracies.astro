---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Missatge enviat | Herbes Remeieres">
    <main class="thanks-container">
        <div class="thanks-content">
            <span class="icon">🌿</span>
            <h1>Gràcies pel teu missatge!</h1>
            <p>Hem rebut el teu correu correctament. Ens posarem en contacte amb tu des de <strong>hola@herbesremeieres.cat</strong> ben aviat.</p>
            <a href="/" class="home-btn">Tornar a l'inici</a>
        </div>
    </main>
</Layout>

<style>
    .thanks-container {
        min-height: 60vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem;
    }

    .thanks-content {
        text-align: center;
        max-width: 500px;
        background-color: var(--bg-secondary);
        padding: 3rem 2rem;
        border-radius: var(--radius-md);
        border: 1px solid var(--border-default);
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05);
    }

    .icon {
        font-size: 4rem;
        display: block;
        margin-bottom: 1rem;
    }

    h1 {
        color: var(--text-primary);
        font-size: 2rem;
        margin-bottom: 1rem;
    }

    p {
        color: var(--text-secondary);
        font-size: 1.1rem;
        line-height: 1.5;
        margin-bottom: 2rem;
    }

    .home-btn {
        display: inline-block;
        background-color: var(--accent-green);
        color: var(--bg-primary);
        padding: 0.75rem 1.5rem;
        text-decoration: none;
        font-weight: bold;
        font-family: var(--font-body);
        border-radius: var(--radius-sm);
    }

    @media (prefers-reduced-motion: no-preference) {
        .home-btn {
            transition: background-color 150ms ease-out, transform 150ms ease-out;
        }

        .home-btn:hover {
            background-color: var(--accent-green-hover);
            transform: translateY(-1px);
        }

        .home-btn:active {
            transform: scale(0.98);
        }
    }
</style>
