---
import Layout from '../layouts/Layout.astro';
---

<Layout title="El Projecte | Herbes Remeieres">
	<div class="projecte-container">
		<h1>El Nostre Projecte</h1>
		<p>
			Aquesta pàgina està en construcció. Aquí explicarem la història de com
			recuperem la saviesa ancestral de la nostra terra i la importància de
			les herbes remeieres.
		</p>
	</div>
</Layout>

<style>
	.projecte-container {
		max-width: var(--content-narrow);
		margin: 0 auto;
		padding: var(--sp-7) var(--sp-4);
	}

	.projecte-container h1 {
		font-size: 2.5rem;
		color: var(--text-primary);
		margin-bottom: var(--sp-5);
		margin-top: 0;
	}

	.projecte-container p {
		font-size: 1.125rem;
		color: var(--text-secondary);
		line-height: 1.7;
	}
</style>
