---
import { ClientRouter } from 'astro:transitions';
import '../styles/design-tokens.css';
import ThemeToggle from '../components/ThemeToggle.astro';

const { title } = Astro.props;
---

<html lang="ca">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>

    <!-- Script anti-FOUC: inicialitza el tema SEMPRE abans del primer renderitzat -->
    <script is:inline>
      (function () {
        var saved = localStorage.getItem('theme');
        var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        // Sempre escrivim data-theme (o 'dark' o 'light') per evitar conflictes
        // amb @media (prefers-color-scheme: dark) quan l'usuari ha triat manualment
        if (saved === 'dark' || (!saved && prefersDark)) {
          document.documentElement.setAttribute('data-theme', 'dark');
        } else {
          document.documentElement.setAttribute('data-theme', 'light');
        }
      })();
    </script>

    <ClientRouter />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=Lato:wght@300;400;500;700&display=swap" rel="stylesheet">

    <style is:global>
      * { box-sizing: border-box; }

      body {
        margin: 0;
        padding: 0;
      }

      h1, h2, h3, h4, .logo {
        font-family: var(--font-display);
      }

      main { padding: 2rem; max-width: 1200px; margin: 0 auto; min-height: 80vh; }

      /* CAPÇALERA STICKY I INTEL·LIGENT */
      .capcalera-principal {
        position: sticky;
        top: 0;
        z-index: 1000;
        background: var(--nav-bg);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--border-subtle);
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);
      }

      @media (prefers-reduced-motion: no-preference) {
        .capcalera-principal {
          transition: transform 0.3s ease-in-out;
        }
      }

      /* Aquesta és la classe que afegirà el JS per amagar el menú */
      .capcalera-principal.amagada {
        transform: translateY(-100%);
      }

      .nav-container { max-width: 1200px; margin: 0 auto; padding: 1rem 2rem; display: flex; justify-content: space-between; align-items: center; }
      .logo { font-size: 1.5rem; font-weight: 600; color: var(--accent-green); text-decoration: none; }

      .enllacos-escriptori { display: flex; gap: 2rem; align-items: center; }
      .enllacos-escriptori a { color: var(--text-primary); text-decoration: none; font-family: var(--font-body); font-size: 0.9375rem; font-weight: 400; }
      .enllacos-escriptori a:hover { color: var(--accent-green); }

      @media (prefers-reduced-motion: no-preference) {
        .enllacos-escriptori a { transition: color 200ms ease-out; }
      }

      .enllacos-escriptori a.destacat { background: var(--accent-green); color: var(--bg-primary); padding: 0.5rem 1.2rem; border-radius: 99px; }
      .enllacos-escriptori a.destacat:hover { background: var(--accent-green-hover); color: var(--bg-primary); }

      @media (prefers-reduced-motion: no-preference) {
        .enllacos-escriptori a.destacat { transition: background 150ms ease-out, transform 150ms ease-out; }
        .enllacos-escriptori a.destacat:hover { transform: translateY(-1px); }
        .enllacos-escriptori a.destacat:active { transform: scale(0.98); }
      }

      .nav-accions { display: flex; align-items: center; gap: 0.5rem; }
      .bot-hamburguesa { display: none; flex-direction: column; gap: 6px; background: transparent; border: none; cursor: pointer; z-index: 1001; padding: 0; }
      .linia { width: 30px; height: 3px; background: var(--accent-green); border-radius: 3px; }

      @media (prefers-reduced-motion: no-preference) {
        .linia { transition: all 0.3s ease; }
      }

      .menu-mobil {
        position: fixed; top: 0; left: 0; width: 100%; height: 100vh;
        background: var(--bg-primary);
        display: flex; flex-direction: column; justify-content: center; align-items: center; gap: 2rem;
        opacity: 0; pointer-events: none;
        z-index: 999;
      }

      @media (prefers-reduced-motion: no-preference) {
        .menu-mobil { transition: opacity 0.3s ease; }
      }

      .menu-mobil.obert { opacity: 1; pointer-events: auto; }
      .menu-mobil a { font-size: 1.5rem; font-family: var(--font-display); color: var(--text-primary); text-decoration: none; font-weight: 500; }
      .menu-mobil a:hover { color: var(--accent-green); }
      .menu-mobil-tema { margin-top: 1rem; }

      .bot-hamburguesa.actiu .linia:nth-child(1) { transform: translateY(9px) rotate(45deg); }
      .bot-hamburguesa.actiu .linia:nth-child(2) { opacity: 0; }
      .bot-hamburguesa.actiu .linia:nth-child(3) { transform: translateY(-9px) rotate(-45deg); }

      @media (max-width: 768px) {
        .enllacos-escriptori { display: none; }
        .bot-hamburguesa { display: flex; }
        .nav-container { padding: 1rem; }
        main { padding: 1rem; }
        /* El toggle del header s'amaga en mòbil: només es veu dins el menú desplegat */
        .nav-accions :global(.theme-toggle) { display: none; }
      }

      /* --- PEU DE PÀGINA (FOOTER) --- */
      .peu-pagina {
        background-color: var(--footer-bg);
        color: var(--text-secondary);
        margin-top: 5rem;
        padding-top: 4rem;
      }

      .footer-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 2rem;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 3rem;
        margin-bottom: 3rem;
      }

      .footer-col h3, .footer-col h4 {
        color: var(--text-primary);
        font-family: var(--font-display);
        margin-top: 0;
        margin-bottom: 1.2rem;
      }

      .footer-col h3 { font-size: 1.5rem; }
      .footer-col h4 { font-size: 1.2rem; }

      .footer-col p {
        line-height: 1.6;
        font-size: 0.95rem;
      }

      .footer-col ul {
        list-style: none;
        padding: 0;
        margin: 0;
      }

      .footer-col ul li { margin-bottom: 0.8rem; }

      .footer-col a {
        color: var(--text-secondary);
        text-decoration: none;
        font-size: 0.95rem;
      }

      @media (prefers-reduced-motion: no-preference) {
        .footer-col a { transition: color 200ms ease-out; }
      }

      .footer-col a:hover {
        color: var(--text-primary);
        text-decoration: underline;
      }

      .footer-bottom {
        text-align: center;
        padding: 1.5rem;
        border-top: 1px solid var(--border-subtle);
        font-size: 0.85rem;
        color: var(--text-tertiary);
      }
    </style>
  </head>
  <body>

    <header class="capcalera-principal">
      <nav class="nav-container">
        <a href="/" class="logo">🌿 Herbes Remeieres</a>

        <div class="enllacos-escriptori">
          <a href="/">Inici</a>
          <a href="/projecte">El Projecte</a>
          <a href="/glossari">Glossari</a>
          <a href="/contacte">Contacte</a>
          <a href="/cataleg" class="destacat">Herbari</a>
        </div>

        <div class="nav-accions">
          <ThemeToggle />
          <button class="bot-hamburguesa" aria-label="Obrir menú">
            <span class="linia"></span>
            <span class="linia"></span>
            <span class="linia"></span>
          </button>
        </div>
      </nav>
    </header>

    <div class="menu-mobil">
      <a href="/">Inici</a>
      <a href="/projecte">El Projecte</a>
      <a href="/cataleg">Herbari</a>
      <a href="/glossari">Glossari</a>
      <a href="/contacte">Contacte</a>
      <div class="menu-mobil-tema">
        <ThemeToggle />
      </div>
    </div>

    <main>
      <slot />
    </main>

    <footer class="peu-pagina">
      <div class="footer-container">
        <div class="footer-col">
          <h3>🌿 Herbes Remeieres</h3>
          <p>Preservant el coneixement etnobotànic i les tradicions medicinals per a les futures generacions. Un projecte nascut de l'amor per la nostra terra.</p>
        </div>

        <div class="footer-col">
          <h4>Navegació</h4>
          <ul>
            <li><a href="/">Inici</a></li>
            <li><a href="/cataleg">Herbari</a></li>
            <li><a href="/projecte">El Projecte</a></li>
            <li><a href="/glossari">Glossari</a></li>
          </ul>
        </div>

        <div class="footer-col">
          <h4>Legal i Contacte</h4>
          <ul>
            <li><a href="#">Avís Legal</a></li>
            <li><a href="#">Política de Privacitat</a></li>
            <li><a href="#">Instagram (@herbesremeieres)</a></li>
            <li><a href="mailto:hola@herbesremeieres.cat">hola@herbesremeieres.cat</a></li>
          </ul>
        </div>
      </div>

      <div class="footer-bottom">
        <p>&copy; 2026 Herbes Remeieres. Cuidant les tradicions.</p>
      </div>
    </footer>

    <script>
      // Variables per al control de l'scroll
      let ultimScroll = 0;

      // Funció que comprova si estem baixant o pujant
      const controlarScroll = () => {
        const capcalera = document.querySelector('.capcalera-principal');
        if (!capcalera) return;

        const actualScroll = window.scrollY;

        // Si baixem (més de 80px per no amagar-lo a dalt de tot)
        if (actualScroll > ultimScroll && actualScroll > 80) {
          capcalera.classList.add('amagada');
        }
        // Si pugem
        else {
          capcalera.classList.remove('amagada');
        }

        ultimScroll = actualScroll;
      };

      document.addEventListener('astro:page-load', () => {
        // --- LÒGICA DEL MENÚ MÒBIL ---
        const boto = document.querySelector('.bot-hamburguesa');
        const menu = document.querySelector('.menu-mobil');
        const enllacosMobil = document.querySelectorAll('.menu-mobil a');

        if(boto && menu) {
          boto.addEventListener('click', () => {
            boto.classList.toggle('actiu');
            menu.classList.toggle('obert');
            document.body.style.overflow = menu.classList.contains('obert') ? 'hidden' : '';
          });

          enllacosMobil.forEach(enllac => {
            enllac.addEventListener('click', () => {
              boto.classList.remove('actiu');
              menu.classList.remove('obert');
              document.body.style.overflow = '';
            });
          });
        }

        // --- LÒGICA DE LA CAPÇALERA INTEL·LIGENT ---
        // Primer netegem l'esdeveniment per evitar duplicats en navegar
        window.removeEventListener('scroll', controlarScroll);
        // L'afegim de nou
        window.addEventListener('scroll', controlarScroll);
      });
    </script>
  </body>
</html>
